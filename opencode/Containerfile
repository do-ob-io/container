# hadolint global ignore=DL3007,DL3018
FROM cgr.dev/chainguard/wolfi-base:latest

# Base runtime, build, and developer tooling. Wolfi is glibc-based, so opencode
# and the language toolchains use standard (non-musl) Linux builds.
#   shadow  -> useradd/groupadd/usermod for the non-root user
#   build-base, python3, nodejs, npm -> language toolchains and native builds
#   openssh-client -> ssh client for cloning SSH git remotes
#   grep, findutils, tree, lsof, fd -> developer/file CLIs (GNU grep and find
#                 replace the limited busybox applets; fd provides glob matching)
#   curl, wget -> download tools available at both build and runtime.
# The remaining packages are best-effort shared libraries for the Playwright
# browsers; apk coverage is not exhaustive (WebKit in particular may still need
# additional libraries at runtime). The common tools cat, sed, rm, mv, and ping
# are provided by the base busybox.
RUN apk add --no-cache \
  bash \
  zsh \
  git \
  git-lfs \
  openssh-client \
  grep \
  findutils \
  tree \
  lsof \
  fd \
  curl \
  wget \
  ca-certificates \
  gzip \
  unzip \
  build-base \
  shadow \
  python3 \
  python3-dev \
  nodejs \
  npm \
  nss \
  freetype \
  harfbuzz \
  glib \
  gtk-3 \
  cairo \
  pango \
  mesa \
  dbus \
  fontconfig

# Non-root user matching the dev container conventions (uid/gid 1000).
RUN groupadd --gid 1000 opencode \
  && useradd --uid 1000 --gid 1000 --create-home --shell /bin/zsh opencode

# Headless no-op `xdg-open` shim. opencode tries to open the web UI in a local
# browser (e.g. `xdg-open http://localhost:4096`), which has nowhere to go in a
# container and otherwise crashes with ENOENT. The shim prints the URL instead
# so it stays visible in the logs; reach the UI from the host browser.
COPY xdg-open.sh /usr/local/bin/xdg-open
RUN chmod 0755 /usr/local/bin/xdg-open

# Development tooling installer and runtime entrypoint, run/installed below.
COPY --chown=opencode:opencode setup.sh /usr/local/bin/setup.sh
COPY --chown=opencode:opencode entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/setup.sh /usr/local/bin/entrypoint.sh

ENV HOME=/home/opencode \
  SHELL=/bin/zsh \
  PATH=/home/opencode/.opencode/bin:/home/opencode/.cargo/bin:/home/opencode/.local/bin:/home/opencode/.npm-global/bin:/usr/local/bin:/usr/bin:/bin

USER opencode
WORKDIR /home/opencode

# Empty global gitignore; add patterns here or by mounting a .gitignore at runtime.
RUN touch /home/opencode/.gitignore \
  && git config --global core.excludesFile /home/opencode/.gitignore

# Install Oh My Zsh, uv + Python + ty/ruff, Rust + rust-analyzer, pnpm +
# typescript + the Playwright CLI, and opencode (see setup.sh). Playwright
# browsers are fetched lazily on first start by the entrypoint.
RUN /usr/local/bin/setup.sh

# The entrypoint lazily downloads Playwright browsers in the background on first
# run, then execs opencode, passing through any subcommand and flags, e.g.:
#   docker run --name opencode-web <image> web --hostname 0.0.0.0 --port 4096
WORKDIR /home/opencode/projects
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
